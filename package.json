{
  "name": "search-typeahead",
  "version": "1.0.0",
  "description": "Search Typeahead System with distributed caching, consistent hashing, trending searches, and batch writes",
  "main": "src/server.js",
  "scripts": {
    "start": "node --experimental-sqlite src/server.js",
    "dev": "node --experimental-sqlite --watch-path=src src/server.js",
    "generate-data": "node data/generate-dataset.js",
    "seed": "node --experimental-sqlite src/db/seed.js",
    "setup": "npm run generate-data && npm run seed"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "redis": "^4.7.1"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
