PORT=3000
DB_PATH=./data/typeahead.db
CACHE_NODES=4
CACHE_VIRTUAL_NODES=150
CACHE_TTL_SECONDS=60
CACHE_MAX_SIZE=1000
BATCH_FLUSH_INTERVAL_MS=5000
BATCH_MAX_SIZE=100
SUGGESTION_LIMIT=10
TRENDING_WINDOW_1H_MS=3600000
TRENDING_WINDOW_24H_MS=86400000

# Redis (L2 cache + trending persistence)
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=300
REDIS_ENABLED=true
